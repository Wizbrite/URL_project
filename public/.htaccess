RewriteEngine On

# --- DEPLOYMENT NOTE ---
# Uncomment ONE of the two RewriteBase lines below depending on your environment:
#
# Option A: Local Laragon/WAMP (Windows) – app is in a subdirectory
RewriteBase /URL_project/public/

# Option B: Unix production server using a virtual host (document root = public/)
# RewriteBase /

# Redirect to index.php if the requested file/folder doesn't exist
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]
